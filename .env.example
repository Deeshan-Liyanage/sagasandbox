# Copy to .env.local for local development.
# Deployed env: Vercel → Project → Settings → Environment Variables.
# Orchestrator runbook: docs/integrations/vercel-supabase-orchestrator.md

# Supabase (optional for Vercel preview — workspace uses mock data; realtime no-ops when unset)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Preferred: Supabase secret key (sb_secret_...)
SUPABASE_SECRET_KEY=
# Backward compatibility only (legacy JWT service_role key)
SUPABASE_SERVICE_ROLE_KEY=
# Optional alias some dashboards use for the secret key
# SUPABASE_SB_KEY=

# Fal.ai (generative media + TTS via fal-ai/kokoro — also set as Supabase Edge secret)
FAL_KEY=

# Site URL (fal webhooks, auth redirects).
# On Vercel, falls back automatically to https://${VERCEL_URL} when unset,
# so fal.ai webhooks still reach the deployment. Override for custom domains.
# Local dev: leave blank — fal.queue.submit() requires a public URL, so the
# code falls back to fal.subscribe() (synchronous polling) instead.
# Production example: https://sagasandbox-theta.vercel.app
NEXT_PUBLIC_SITE_URL=

# Supabase Dashboard → Authentication → Providers → Email: enable password sign-in.
# REQUIRED (one project, all Vercel envs): turn OFF "Confirm email" for instant sign-up/sign-in.
#   Path: Authentication → Providers → Email → Confirm email (disabled).
# Redirect URLs must include {NEXT_PUBLIC_SITE_URL or origin}/auth/callback (OAuth + email links).

# Dev auth bypass — skip email/password (local npm run dev; preview/prod need ?key= secret)
AUTH_DEV_BYPASS_ENABLED=false
AUTH_DEV_BYPASS_SECRET=
DEV_BYPASS_EMAIL=dev@sagasandbox.local
AUTH_DEV_BYPASS_ALLOW_PRODUCTION=false

# Demo seed (scripts/seed-demo.ts) — auth.users UUID for project owner
DEMO_OWNER_ID=

# OpenAI (Creative Copilot + Tier B scenery layout planner)
OPENAI_API_KEY=
# Optional: OpenAI-compatible API base (LM Studio, Azure OpenAI proxy, etc.)
# OPENAI_BASE_URL=

# Tier B scenery: optional final img2img pass after landmark composite (extra Fal cost)
# SCENERY_ENABLE_HARMONIZE=true

# Inngest (background jobs)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
