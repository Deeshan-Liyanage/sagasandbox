# Copy to .env.local for local development.
# Deployed env: Vercel → Project → Settings → Environment Variables.
# Orchestrator runbook: docs/integrations/vercel-supabase-orchestrator.md

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Fal.ai (generative media)
FAL_KEY=

# Site URL (fal webhooks, auth redirects)
NEXT_PUBLIC_SITE_URL=

# ElevenLabs (audio export edge function)
ELEVENLABS_API_KEY=

# OpenAI (Creative Copilot)
OPENAI_API_KEY=

# Inngest (background jobs)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
